<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nostalgic Trees — Tree Config Generator</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&family=Nunito:wght@400;600;700&display=swap');

    :root {
      --bg: #1a1a2e;
      --surface: #16213e;
      --accent: #e94560;
      --accent2: #53d769;
      --text: #eee;
      --text-dim: #8899aa;
      --border: #2a3a5e;
      --input-bg: #0d1b36;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Nunito', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    .container {
      position: relative;
      z-index: 1;
      max-width: 1100px;
      margin: 0 auto;
      padding: 40px 24px;
    }

    header { text-align: center; margin-bottom: 48px; }
    header h1 { font-family: 'Silkscreen', cursive; font-size: 2.4rem; color: var(--accent2); }
    header p { color: var(--text-dim); margin-top: 8px; }

    .main-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
    @media (max-width: 768px) { .main-grid { grid-template-columns: 1fr; } }

    .panel {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 28px;
    }

    .panel h2 {
      font-family: 'Silkscreen', cursive;
      font-size: 1.1rem;
      color: var(--accent);
      margin-bottom: 20px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .form-group { margin-bottom: 18px; }

    .form-group label {
      display: block;
      font-weight: 700;
      font-size: 0.85rem;
      color: var(--text-dim);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6px;
    }

    .form-group input[type="text"],
    .form-group input[type="number"],
    .form-group select {
      width: 100%;
      padding: 10px 14px;
      background: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      color: var(--text);
      font-family: 'Nunito', sans-serif;
      font-size: 0.95rem;
      outline: none;
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus { border-color: var(--accent2); }

    .form-group .hint { font-size: 0.75rem; color: var(--text-dim); margin-top: 4px; }

    .color-section { display: flex; gap: 12px; align-items: flex-end; }
    .color-section .color-input-wrap { flex: 1; }

    .color-section input[type="color"] {
      width: 56px;
      height: 42px;
      border: 2px solid var(--border);
      border-radius: 8px;
      background: var(--input-bg);
      cursor: pointer;
      padding: 2px;
    }

    .color-section input[type="color"]::-webkit-color-swatch-wrapper { padding: 2px; }
    .color-section input[type="color"]::-webkit-color-swatch { border-radius: 4px; border: none; }

    .preview-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .preview-item { text-align: center; }

    .preview-item canvas {
      image-rendering: pixelated;
      width: 64px;
      height: 64px;
      border: 2px solid var(--border);
      border-radius: 6px;
      background: #2a2a4a;
      display: block;
      margin: 0 auto 6px;
    }

    .preview-item span {
      font-size: 0.7rem;
      color: var(--text-dim);
      font-family: 'Silkscreen', cursive;
    }

    .json-output {
      position: relative;
      background: var(--input-bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 16px;
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
      color: var(--accent2);
      white-space: pre;
      overflow-x: auto;
      line-height: 1.6;
    }

    .req-mod-toggle { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
    .req-mod-toggle input[type="checkbox"] { width: 18px; height: 18px; accent-color: var(--accent2); cursor: pointer; }
    .req-mod-toggle label { font-weight: 600; font-size: 0.85rem; color: var(--text-dim); cursor: pointer; }

    .req-mod-field { display: none; }
    .req-mod-field.visible { display: block; }

    .instructions {
      margin-top: 24px;
      padding: 16px;
      background: rgba(83, 215, 105, 0.05);
      border: 1px solid rgba(83, 215, 105, 0.15);
      border-radius: 8px;
      font-size: 0.82rem;
      color: var(--text-dim);
      line-height: 1.7;
    }

    .instructions strong { color: var(--accent2); }
    .instructions code { background: var(--input-bg); padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; color: var(--accent); }
  </style>
</head>
<body>
  <div class="container">
    <header>
      <h1>Nostalgic Trees</h1>
      <p>Tree Config Generator — Create custom resource trees for your modpack</p>
    </header>
    <div class="main-grid">
      <div class="panel">
        <h2>⚙ Tree Properties</h2>
        <div class="form-group">
          <label>Tree Name</label>
          <input type="text" id="treeName" placeholder="e.g. tin, uranium, ruby" oninput="update()">
          <div class="hint">Lowercase, no spaces. This becomes the ID prefix.</div>
        </div>
        <div class="form-group">
          <label>Tier</label>
          <select id="treeTier" onchange="update()">
            <option value="tier_1">Tier 1 — Basic</option>
            <option value="tier_2">Tier 2 — Common</option>
            <option value="tier_3" selected>Tier 3 — Intermediate</option>
            <option value="tier_4">Tier 4 — Advanced</option>
            <option value="tier_5">Tier 5 — Rare</option>
          </select>
          <div class="hint">Affects mallet durability cost.</div>
        </div>
        <div class="form-group">
          <label>Output Item</label>
          <input type="text" id="outputItem" placeholder="e.g. mekanism:raw_tin" oninput="update()">
          <div class="hint">Full item ID including mod namespace.</div>
        </div>
        <div class="form-group">
          <label>Output Count</label>
          <input type="number" id="outputCount" value="1" min="1" max="64" onchange="update()">
          <div class="hint">Items per chunk + apple craft.</div>
        </div>
        <div class="form-group">
          <label>Color</label>
          <div class="color-section">
            <div class="color-input-wrap">
              <input type="text" id="colorHex" placeholder="C9A78B" value="C9A78B" oninput="syncHex();update()">
            </div>
            <input type="color" id="colorPicker" value="#C9A78B" oninput="syncPicker();update()">
          </div>
          <div class="hint">Hex color — tints all tree blocks and items.</div>
        </div>
        <div class="req-mod-toggle">
          <input type="checkbox" id="reqModCheck" onchange="toggleMod();update()">
          <label for="reqModCheck">Requires a mod to be loaded</label>
        </div>
        <div class="form-group req-mod-field" id="reqModField">
          <label>Required Mod ID</label>
          <input type="text" id="reqMod" placeholder="e.g. mekanism" oninput="update()">
          <div class="hint">Tree only loads if this mod is present.</div>
        </div>
      </div>
      <div>
        <div class="panel" style="margin-bottom: 24px;">
          <h2>👁 Preview</h2>
          <div class="preview-grid">
            <div class="preview-item"><canvas id="cvLog" width="16" height="16"></canvas><span>Log</span></div>
            <div class="preview-item"><canvas id="cvLogTop" width="16" height="16"></canvas><span>Log Top</span></div>
            <div class="preview-item"><canvas id="cvLeaves" width="16" height="16"></canvas><span>Leaves</span></div>
            <div class="preview-item"><canvas id="cvSapling" width="16" height="16"></canvas><span>Sapling</span></div>
            <div class="preview-item"><canvas id="cvStripped" width="16" height="16"></canvas><span>Stripped</span></div>
            <div class="preview-item"><canvas id="cvStrippedTop" width="16" height="16"></canvas><span>Strip Top</span></div>
            <div class="preview-item"><canvas id="cvApple" width="16" height="16"></canvas><span>Apple</span></div>
            <div class="preview-item"><canvas id="cvChunk" width="16" height="16"></canvas><span>Chunk</span></div>
          </div>
        </div>
        <div class="panel">
          <h2>📋 JSON Config</h2>
          <div class="json-output" id="jsonOutput">{}</div>
          <div class="instructions">
            <strong>How to use:</strong><br>
            1. Save as <code>&lt;name&gt;.json</code><br>
            2. Place in <code>config/nostalgictrees/trees/</code><br>
            3. Restart the game<br><br>
            The mod auto-generates all blocks, items, textures, recipes, and JEI entries.
          </div>
        </div>
      </div>
    </div>
  </div>
