<div class="container">
  <header><h1>Nostalgic Trees</h1><p>Tree Config Generator — Create custom resource trees for your modpack</p></header>
  <div class="main-grid">
    <div class="panel">
      <h2>⚙ Tree Properties</h2>
      <div class="form-group"><label>Tree Name</label><input type="text" id="treeName" placeholder="e.g. tin, uranium, ruby" oninput="update()"><div class="hint">Lowercase, no spaces. This becomes the ID prefix.</div></div>
      <div class="form-group"><label>Tier</label><select id="treeTier" onchange="update()"><option value="tier_1">Tier 1 — Basic</option><option value="tier_2">Tier 2 — Common</option><option value="tier_3" selected>Tier 3 — Intermediate</option><option value="tier_4">Tier 4 — Advanced</option><option value="tier_5">Tier 5 — Rare</option></select><div class="hint">Affects mallet durability cost.</div></div>
      <div class="form-group"><label>Output Item</label><input type="text" id="outputItem" placeholder="e.g. mekanism:raw_tin" oninput="update()"><div class="hint">Full item ID including mod namespace.</div></div>
      <div class="form-group"><label>Output Count</label><input type="number" id="outputCount" value="1" min="1" max="64" onchange="update()"><div class="hint">Items per chunk + apple craft.</div></div>
      <div class="form-group"><label>Color</label><div class="color-section"><div class="color-input-wrap"><input type="text" id="colorHex" placeholder="C9A78B" value="C9A78B" oninput="syncHex();update()"></div><input type="color" id="colorPicker" value="#C9A78B" oninput="syncPicker();update()"></div><div class="hint">Hex color — tints all tree blocks and items.</div></div>
      <div class="req-mod-toggle"><input type="checkbox" id="reqModCheck" onchange="toggleMod();update()"><label for="reqModCheck">Requires a mod to be loaded</label></div>
      <div class="form-group req-mod-field" id="reqModField"><label>Required Mod ID</label><input type="text" id="reqMod" placeholder="e.g. mekanism" oninput="update()"><div class="hint">Tree only loads if this mod is present.</div></div>
    </div>
    <div>
      <div class="panel" style="margin-bottom:24px;">
        <h2>👁 Preview</h2>
        <div class="preview-grid">
          <div class="preview-item"><canvas id="cvLog" width="16" height="16"></canvas><span>Log</span></div>
          <div class="preview-item"><canvas id="cvLogTop" width="16" height="16"></canvas><span>Log Top</span></div>
          <div class="preview-item"><canvas id="cvLeaves" width="16" height="16"></canvas><span>Leaves</span></div>
          <div class="preview-item"><canvas id="cvSapling" width="16" height="16"></canvas><span>Sapling</span></div>
          <div class="preview-item"><canvas id="cvStripped" width="16" height="16"></canvas><span>Stripped</span></div>
          <div class="preview-item"><canvas id="cvStrippedTop" width="16" height="16"></canvas><span>Strip Top</span></div>
          <div class="preview-item"><canvas id="cvApple" width="16" height="16"></canvas><span>Apple</span></div>
          <div class="preview-item"><canvas id="cvChunk" width="16" height="16"></canvas><span>Chunk</span></div>
        </div>
      </div>
      <div class="panel">
        <h2>📋 JSON Config</h2>
        <div class="json-output" id="jsonOutput">{}</div>
        
        <div class="instructions"><strong>How to use:</strong><br>1. Save as <code>&lt;name&gt;.json</code><br>2. Place in <code>config/nostalgictrees/trees/</code><br>3. Restart the game<br><br>The mod auto-generates all blocks, items, textures, recipes, and JEI entries.</div>
      </div>
    </div>
  </div>
</div>
